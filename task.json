            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Setup: Interactive Agent Builder",
            "type": "shell",
            "command": "./build_agent_interactive.sh",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Setup: Add Part 6 (OCB)",
            "type": "shell",
            "command": "./create_agent_part6.sh",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Setup: Add Part 7 (Dynatrace)",
            "type": "shell",
            "command": "./create_agent_part7.sh",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Validate: Agent YAML Syntax",
            "type": "shell",
            "command": "python3 -c \"import yaml; yaml.safe_load(open('agent/o11y-engineer.agent.yaml')); print('✅ YAML is valid')\"",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Validate: Count Prompts",
            "type": "shell",
            "command": "echo 'Prompt count:' && grep -c '^  - id:' agent/o11y-engineer.agent.yaml && echo 'Expected: 19'",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Validate: Check File Size",
            "type": "shell",
            "command": "ls -lh agent/o11y-engineer.agent.yaml && wc -l agent/o11y-engineer.agent.yaml",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Git: Initial Commit",
            "type": "shell",
            "command": "git add . && git commit -m 'feat: complete B-MAD observability agent'",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Complete Setup",
            "type": "shell",
            "command": "./complete_setup.sh",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
